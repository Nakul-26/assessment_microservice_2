{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Problem",
  "description": "A programming problem",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": ["Easy", "Medium", "Hard"]
    },
    "testCases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "input": {
            "type": "array",
            "items": {}
          },
          "expectedOutput": {},
          "isHidden": {
            "type": "boolean"
          }
        },
        "required": ["input", "expectedOutput"]
      }
    },
    "testsJSON": {
      "type": "string"
    },
    "functionDefinitions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "template": { "type": "string" }
        },
        "required": ["name", "template"]
      }
    },
    "expectedIoType": {
      "type": "object",
      "properties": {
        "functionName": {
          "type": "string"
        },
        "inputParameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" }
            },
            "required": ["name", "type"]
          }
        },
        "returnType": {
          "type": "string"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "isPremium": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["title", "description", "difficulty", "testCases", "functionDefinitions"]
}
