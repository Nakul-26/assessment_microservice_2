{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/submission.json",
  "title": "SubmissionMessage",
  "type": "object",
  "required": ["submissionId", "problemId", "language", "code", "functionName"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "v2" },
    "submissionId": { "type": "string", "minLength": 1 },
    "problemId": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "code": { "type": "string" },
    "functionName": { "type": "string" },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["inputs", "expected"],
        "properties": {
          "type": { "type": "string" },
          "inputs": { "type": "array" },
          "expected": {},
          "meta": { "type": "object" },
          "isHidden": { "type": "boolean" }
        }
      }
    }
  },
  "additionalProperties": true
}
