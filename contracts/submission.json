{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/submission.json",
  "title": "SubmissionMessage",
  "type": "object",
  "required": ["submissionId", "problemId", "language", "code"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "v1" },
    "submissionId": { "type": "string", "minLength": 1 },
    "problemId": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "code": { "type": "string" },
    "functionName": { "type": "string" },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "input", "expectedOutput"],
        "properties": {
          "id": { "type": ["number", "integer"] },
          "type": { "type": "string" },
          "input": {},
          "expectedOutput": {},
          "meta": { "type": "object" },
          "isHidden": { "type": "boolean" }
        }
      }
    }
  },
  "additionalProperties": true
}
