{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submission",
  "description": "A code submission for a problem",
  "type": "object",
  "properties": {
    "problemId": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["Pending", "Running", "Success", "Fail", "Error"]
    },
    "output": {
      "type": "string"
    },

    "testResult": {
      "type": "object",
      "additionalProperties": true
    },
    "userId": {
      "type": "string"
    }
  },
  "required": ["problemId", "code", "language"]
}
